name: Python Continuous Integration

# Trigger the pipeline on pushes or pull requests to key development branches
on:
  push:
    branches: [ "main", "master", "develop" ]
  pull_request:
    branches: [ "main", "master", "develop" ]

jobs:
  validate-and-test:
    # Run the tests on the latest stable Ubuntu environment
    runs-on: ubuntu-latest

    steps:
    # Step 1: Check out your repository code onto the runner
    - name: Checkout Code Repository
      uses: actions/checkout@v4

    # Step 2: Set up a reliable Python runtime environment
    - name: Set up Python 3.11
      uses: actions/setup-python@v5
      with:
        python-python-version: '3.11'
        cache: 'pip' # Speeds up subsequent runs by caching dependencies

    # Step 3: Upgrade pip and install all project dependencies
    - name: Install Application Dependencies
      run: |
        python -m pip install --upgrade pip
        pip install flake8  # Code linting tool
        if [ -f requirements.txt ]; then pip install -r requirements.txt; fi

    # Step 4: Perform linting to catch syntax errors or style violations early
    - name: Lint Code with Flake8
      run: |
        # stop the build if there are Python syntax errors or undefined names
        flake8 . --count --select=E9,F63,F7,F82 --show-source --statistics
        # exit-zero treats all errors as warnings. Two-space indentation logic check.
        flake8 . --count --exit-zero --max-complexity=10 --max-line-length=127 --statistics

    # Step 5: Execute your automated PyTest suite
    - name: Run Automated Test Suite
      # Mock any missing environment files so tests don't break on missing local .env variables
      env:
        GROQ_API_KEY: "API_key_for_ci_pipeline"
      run: |
        pytest tests/
